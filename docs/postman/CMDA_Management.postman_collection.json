{
  "info": {
    "_postman_id": "762be67b-8cd3-4e4a-93ce-48356d893a48",
    "name": "CMDA Management",
    "description": "Collection de reference CMDA DEV. Les requetes sont rangees par domaine metier. Utiliser l'environnement CMDA Local et executer AUTHENTICATION / Authenticate avant les requetes protegees.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "AUTHENTICATION",
      "item": [
        {
          "name": "Authenticate",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "const token = response.token || response.jwt || response.accessToken;",
                  "if (token) {",
                  "  pm.environment.set('jwtToken', token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/authenticate",
            "description": "Authentifie l'utilisateur et stocke automatiquement le token JWT dans l'environnement actif."
          }
        }
      ]
    },
